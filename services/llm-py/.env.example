# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM Service Configuration
LLM_HOST=127.0.0.1
LLM_PORT=8000
LLM_DEFAULT_MODEL=anthropic/claude-3.5-sonnet
LLM_TIMEOUT=30

# RAG Embedding Configuration
DDO_LLM_RAG_MODEL=openai/text-embedding-3-small    # Embedding model for RAG (推荐: openai/text-embedding-3-small, qwen/qwen3-embedding-8b)
# 优先级: DDO_LLM_RAG_MODEL > DDO_LLM_MODEL > 系统默认

# Logging
LOG_LEVEL=INFO

# RAG Configuration (Future Use)
RAG_ENABLED=true
RAG_VECTOR_STORE=chroma
RAG_STORE_PATH=~/.ddo/data/vector/
RAG_TOP_K=5
