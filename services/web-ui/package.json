{
  "name": "ddo-web-ui",
  "version": "0.1.0",
  "description": "Ddo Web UI - CLI extension for visual dashboard and Electron ding client",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "build:electron": "node scripts/build-electron.mjs",
    "dev:all": "concurrently -k \"npm run dev\" \"npm run dev:electron\"",
    "dev:electron": "npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:50003 electron .",
    "electron:dev": "npm run build && npm run build:electron && electron .",
    "electron:build": "npm run build && npm run build:electron && electron-builder",
    "electron:preview": "npm run build && npm run build:electron && electron ."
  },
  "dependencies": {
    "axios": "^1.6.8",
    "chart.js": "^4.5.1",
    "electron-log": "^5.1.2",
    "electron-store": "^8.2.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.2.10",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vue-tsc": "^2.0.6"
  },
  "build": {
    "appId": "com.ddo.ding",
    "productName": "Ddo Ding",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*",
      "electron.mjs"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    }
  }
}
