# OpenRouter Configuration
DDO_OPENROUTER_API_KEY=sk-or-v1-xxx
DDO_LLM_MODEL=anthropic/claude-3.5-sonnet

# LLM Service Configuration
LLM_HOST=127.0.0.1
LLM_PORT=8000
LLM_TIMEOUT=30

# Logging
LOG_LEVEL=INFO

# RAG Configuration (Future Use)
RAG_ENABLED=true
RAG_VECTOR_STORE=chroma
RAG_STORE_PATH=~/.ddo/data/vector/
RAG_EMBEDDING_MODEL=openai/text-embedding-3-small
RAG_TOP_K=5
