{
  "name": "@_djhhh/ddo-cli",
  "version": "0.1.0",
  "description": "Ddo - 个人智能工作空间 CLI",
  "main": "dist/index.js",
  "files": [
    "dist/**/*",
    "vendor/**/*",
    "package.json"
  ],
  "bin": {
    "ddo": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle:services": "node ../../scripts/package-all.mjs",
    "pack:npm": "node ../../scripts/package-all.mjs && npm pack",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest"
  },
  "keywords": [
    "cli",
    "ai",
    "workspace",
    "productivity"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "electron": "^28.2.10",
    "electron-log": "^5.1.2",
    "electron-store": "^8.2.0",
    "fs-extra": "^11.2.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Djhhhhhh",
  "repository": {
    "type": "git",
    "url": "https://github.com/Djhhhhhh/Ddo.git"
  },
  "homepage": "https://github.com/Djhhhhhh/Ddo"
